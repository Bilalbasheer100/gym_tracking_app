# Copy this file to .env.local and fill in your values.
# Get the URI from MongoDB Atlas: Cluster -> Connect -> Drivers.
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"

# Database name (optional, defaults to "gymtracker")
MONGODB_DB="gymtracker"

# Login.
# AUTH_SECRET signs the session cookie. Set it once to any long random string.
AUTH_SECRET="put-a-long-random-string-here"
# APP_PASSWORD is an OPTIONAL one-time bootstrap password. On first sign-in it's
# hashed into MongoDB; after that you change it in-app (Goals -> Change password).
# Leave it blank to instead set your password on a first-run screen.
# (If both AUTH_SECRET and APP_PASSWORD are blank, the app has no login.)
APP_PASSWORD="change-me"
